# ================================================================
# TEMPLATE — copie ce fichier en .env.properties et remplis les valeurs
# Ce fichier EST commité dans Git (il sert de documentation)
# ================================================================

# Base de données
DB_URL=jdbc:mysql://localhost:3306/secogroupe_app?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=CHANGE_ME

# JWT — clé secrète (minimum 32 caractères pour HS256)
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM

# Mail — Resend (https://resend.com)
# Créer un compte, vérifier le domaine secogroupe.com, générer une API key
RESEND_API_KEY=re_CHANGE_ME
MAIL_FROM=hr@secogroupe.com

# URL de base de l'API (liens de vérification email)
# Exemple production : https://api.secogroupe.com
APP_BASE_URL=http://localhost:8080
WEBSITE_URL=CHANGE_ME
APP_FRONTEND_URL=CHANGE_ME
